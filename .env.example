# OpenClaw Skills Repository Configuration
# Copy this file to .env and fill in your credentials
# WARNING: Do not commit .env to version control!

# GitHub Configuration
# Generate at: https://github.com/settings/tokens/new
# Required scopes: repo (all), workflow
GITHUB_TOKEN=your_github_token_here

# Git Configuration
GIT_USER_EMAIL=agent@openclaw.local
GIT_USER_NAME=OpenClaw Agent

# Telegram Integration
# Required for feedback system
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Telegram Topic IDs (for feedback channels)
# Format: {topic_name}={topic_id}
TELEGRAM_TOPIC_GAMBLING=0
TELEGRAM_TOPIC_SEO_TZ=0
TELEGRAM_TOPIC_ANCHOR=0

# DataForSEO Credentials (for SEO TZ agent)
DATAFORSEO_LOGIN=your_dataforseo_email
DATAFORSEO_PASSWORD=your_dataforseo_password

# OpenAI Configuration (for image generation)
OPENAI_API_KEY=your_openai_api_key_here

# SFTP Hosting Configuration (for gambling agent deployments)
SFTP_HOST=your_hosting_domain.com
SFTP_USER=your_ftp_user
SFTP_PASSWORD=your_ftp_password
SFTP_PORT=22

# ISPManager (if using for hosting)
ISPMANAGER_URL=https://your_hosting_domain.com:1500
ISPMANAGER_USER=your_manager_user
ISPMANAGER_PASSWORD=your_manager_password

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=./logs

# Cron Job Scheduling (OpenClaw)
CRON_DAILY_COMMIT=0 2 * * *
CRON_FEEDBACK_SYNC=0 */6 * * *
CRON_WEEKLY_AUDIT=0 8 * * 1

# System Configuration
ENVIRONMENT=production
DEBUG=false
